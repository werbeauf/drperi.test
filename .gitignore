# Code-intelligence indices (regenerable, large, not source)
.gitnexus/
.codegraph/

# Per-tool / per-machine state
# We track the auto-sync hook script + setup instructions + example settings,
# but ignore the user-specific state files (sync log, debounce marker, local
# permissions).
.claude/*
!.claude/hooks/
!.claude/hooks/**
!.claude/settings.example.json
.claude/sync.log
.claude/.last-sync
.gstack/

# OS junk
.DS_Store
Thumbs.db

# Editor swap files
*.swp
*~
.idea/
.vscode/

# PHP dependency dirs (none today; defensive)
vendor/
node_modules/

# Logs
*.log
